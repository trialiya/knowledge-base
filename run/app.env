JAVA_OPTS=-Xmx512m

# ── AI (OpenAI-compatible API) ──
AI_BASE_URL=https://api.openai.com/
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL=gpt-4o-mini

# ── Embedding (OpenAI-compatible API, 1024 dimensions) ──
AI_EMBED_BASE_URL=https://api.openai.com/
AI_EMBED_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_EMBED_MODEL=text-embedding-3-large

# ── Database ──
# For H2 (in-memory, no PostgreSQL needed): set SPRING_PROFILES_ACTIVE=h2
# For PostgreSQL: leave SPRING_PROFILES_ACTIVE empty or set to default
SPRING_PROFILES_ACTIVE=h2
DATASOURCE_URL=jdbc:postgresql://localhost:5432/knowledgebase
DATASOURCE_USERNAME=knowledgebase
DATASOURCE_PASSWORD=knowledgebase

# ── Project ──
# Absolute path to the repository root to be indexed.
# On Windows use forward slashes or double backslashes: C:/projects/my-repo
PROJECT_PATH=..

# ── Jira (optional) ──
JIRA_BASE_URL=
JIRA_TOKEN=

# ── Confluence (optional) ──
CONFLUENCE_BASE_URL=
CONFLUENCE_TOKEN=
