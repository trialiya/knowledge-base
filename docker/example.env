# ── AI (OpenAI-совместимый API) ──
AI_BASE_URL=https://api.openai.com/
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AI_MODEL=deepseek-v4-flash

# ── Embedding (OpenAI-совместимый API - 1024 dimension) ──
AI_EMBED_BASE_URL=https://api.openai.com/
AI_EMBED_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AI_EMBED_MODEL=bge-m3

# ── Database ──
DATASOURCE_URL=jdbc:postgresql://postgres:5432/knowledgebase
DATASOURCE_USERNAME=knowledgebase
DATASOURCE_PASSWORD=knowledgebase

# ── Project ──
# Абсолютный путь к репозиторию на хосте.
PROJECT_PATH_MOUNT=/absolute/path/to/knowledge-base

# ── Jira (опционально) ──
JIRA_BASE_URL=
JIRA_TOKEN=

# ── Confluence (опционально) ──
CONFLUENCE_BASE_URL=
CONFLUENCE_TOKEN=
